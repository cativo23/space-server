# Postfix accounts configuration
# This file is auto-generated from MAIL_ACCOUNTS environment variable
# Format: user@domain|{password_hash}|uid:gid
#
# To add accounts manually, use:
#   docker exec mail setup email add user@domain password
#
# Or add to .env (multiple accounts separated by ;):
#   MAIL_ACCOUNTS=user1@domain.com|pass1|5000:5000;user2@domain.com|pass2|5000:5000
