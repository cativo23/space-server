# Mail Server Configuration

# Your domain
MAIL_DOMAIN=cativo.dev

# Hostname for mail server (usually mail.yourdomain)
MAIL_HOSTNAME=mail

# Email accounts (format: email|password|uid:gid, multiple separated by ;)
# Example: admin@cativo.dev|SecurePass123!|5000:5000;user@cativo.dev|AnotherPass456!|5000:5000
MAIL_ACCOUNTS=admin@cativo.dev|ChangeMe123!|5000:5000

# Max message size (default: 50MB)
POSTFIX_MESSAGE_SIZE_LIMIT=52428800
