# Mailcow Configuration
# Copy this file to .env and fill in your values

# Domain
MAILCOW_DOMAIN=cativo.dev

# Database
MYSQL_ROOT_PASSWORD=change_me_root_password_32chars
MYSQL_DATABASE=mailcow
MYSQL_USER=mailcow
MYSQL_PASSWORD=change_me_mailcow_password_32c

# Dovecot master (for admin access to all mailboxes)
DOVECOT_MASTER_USER=admin
DOVECOT_MASTER_PASS=change_me_dovecot_password

# Timezone
TZ=UTC

# Ports (set to 0 to disable if not needed)
SMTP_PORT=25
SMTPS_PORT=465
SUBMISSION_PORT=587
IMAP_PORT=143
IMAPS_PORT=993
POP3_PORT=110
POP3S_PORT=995
MANAGESIEVE_PORT=4190
